{
  "name": "@akkhar-labs/akkhar-magic",
  "version": "0.0.1",
  "description": "UI-to-API bridge: Intercepts OpenAI-compatible requests and routes them through Google AI Studio via headless Puppeteer",
  "author": "Rahat Hasan <rahat@akkhar-labs.com>",
  "license": "GPL-3.0-or-later",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "bundle": "node scripts/build.cjs",
    "build:exe": "node scripts/build.cjs --sea",
    "build:dist": "node scripts/build.cjs --dist",
    "serve": "node dist/index.js",
    "cli": "tsx src/cli/index.ts",
    "login": "tsx src/cli/index.ts login",
    "switch": "tsx src/cli/index.ts switch",
    "status": "tsx src/cli/index.ts status"
  },
  "bin": {
    "akkhar-magic": "./dist/cli/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "hono": "^4.12.17",
    "puppeteer-core": "^24.43.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.28.0",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
